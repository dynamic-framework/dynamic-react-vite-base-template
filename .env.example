# =============================================================================
# Modyo CLI — Variables de entorno de configuración
# =============================================================================
# Copia este archivo como .env para pruebas locales.
# En producción, usa variables de entorno directas o un archivo .modyo
# (método recomendado por el CLI — ver .modyo en este repo).
#
# Comandos cubiertos: push | preview | support-bundle
# Documentación CLI: https://github.com/modyo/modyo-cli
# Versión CLI usada en este proyecto: @modyo/cli@3.6.2
#
# NOTA: El soporte de .env está deprecado en el CLI y será removido en
# versiones futuras. Se mantiene por retrocompatibilidad.
# =============================================================================


# -----------------------------------------------------------------------------
# ✅ REQUERIDAS — Necesarias para push y preview
# -----------------------------------------------------------------------------

# URL base de tu cuenta Modyo (sin trailing slash)
# Usado en: push, preview
MODYO_ACCOUNT_URL=https://my-account.modyo.cloud

# Token de API para autenticación con la plataforma
# Generar en: Admin > Settings > API Access > Access Tokens
# ⚠️  Nunca commitear con valor real — .env y .modyo están en .gitignore
# Usado en: push, preview
MODYO_TOKEN=my-api-token-here

# Nombre del widget en la plataforma Modyo (identificador único)
# Técnicamente opcional en el CLI (infiere el valor del campo "name" en package.json),
# pero en este template ese valor es el nombre del template y no es válido como nombre
# de widget en producción — debe definirse explícitamente.
# Usado en: push
MODYO_WIDGET_NAME=my-widget-name


# -----------------------------------------------------------------------------
# ✅ IDENTIFICACIÓN DEL SITIO — Usar UNO de los dos (push y preview)
# -----------------------------------------------------------------------------

# Host del sitio donde se desplegará/previsualizará el widget
# Ejemplo: mi-sitio (sin dominio completo)
# Usado en: push, preview
MODYO_SITE_HOST=my-site

# ID numérico del sitio (alternativa a MODYO_SITE_HOST)
# Consultar en: Admin > Channels > Sites > [sitio] > Settings
# Usado en: push, preview
# MODYO_SITE_ID=123


# -----------------------------------------------------------------------------
# ⚙️  OPCIONALES — push: comportamiento del deploy
# -----------------------------------------------------------------------------

# Versión de la plataforma Modyo (8 | 9 | 10) — Default: 9
# Usado en: push, preview
# MODYO_VERSION=9

# Directorio que contiene el resultado del build — Default: dist (build en este proyecto)
# Usado en: push
# MODYO_BUILD_DIRECTORY=build

# Nombre del script de build a ejecutar (definido en package.json) — Default: build
# Usado en: push
# MODYO_BUILD_COMMAND=build

# Regex de archivos a excluir del bundle subido a la plataforma
# Ejemplo: \.map$ (excluir source maps)
# Usado en: push
# MODYO_REGEX_EXCLUDE=

# Regex para deshabilitar el procesamiento Liquid en archivos que coincidan
# Útil cuando el widget usa sintaxis {{ }} que conflictúa con Liquid
# Usado en: push
# MODYO_DISABLE_LIQUID_REGEX=


# -----------------------------------------------------------------------------
# ⚙️  OPCIONALES — push: ZIP mode (widgets con code splitting)
# -----------------------------------------------------------------------------
# Activar cuando el widget usa code splitting (múltiples chunks).
# ⚠️  El ZIP mode es EXCLUSIVO para Webpack — no compatible con Vite por defecto.

# Habilitar empaquetado en ZIP para widgets con code splitting — Default: false
# Usado en: push
# MODYO_ZIP=false

# Archivo JS de entrada dentro del ZIP — Default: main.js
# Usado en: push (solo con MODYO_ZIP=true)
# MODYO_ZIP_ENTRY_JS=main.js

# Archivo CSS de entrada dentro del ZIP — Default: main.css
# Usado en: push (solo con MODYO_ZIP=true)
# MODYO_ZIP_ENTRY_CSS=main.css


# -----------------------------------------------------------------------------
# ⚙️  OPCIONALES — preview: servidor local
# -----------------------------------------------------------------------------

# Puerto del servidor de preview local — Default: 8080
# Usado en: preview
# MODYO_LOCAL_PORT=8080

# ID del contenedor DOM donde se montará el widget durante el preview
# Default: nombre del widget
# Usado en: preview
# MODYO_LOCAL_DOM_ID=app

# Archivo JS de entrada para el preview — Default: main.js
# Usado en: preview
# MODYO_LOCAL_ENTRY_JS=main.js

# Cargar el JS como ES Module (type="module") — Default: false
# Usado en: preview
# MODYO_LOCAL_MODULE=false


# -----------------------------------------------------------------------------
# ⚙️  OPCIONALES — Diagnóstico y support-bundle
# -----------------------------------------------------------------------------

# Habilitar logging de diagnóstico (equivalente al flag --log en cada comando)
# Genera una sesión en MODYO_LOG_DIR con traza completa de la ejecución
# Útil en CI/CD para depuración de fallos — Default: 0 (desactivado)
# Usado en: push, preview, get
# MODYO_LOG=0

# Directorio donde se guardan las sesiones de diagnóstico — Default: .modyo-debug/
# También indica a support-bundle dónde buscar las sesiones
# Usado en: push, preview, get, support-bundle
# MODYO_LOG_DIR=.modyo-debug/

# Número de sesiones de diagnóstico recientes a conservar — Default: 20, mínimo: 1
# Usado en: push, preview, get
# MODYO_LOG_KEEP=20


# =============================================================================
# NOTAS
# =============================================================================
# - El método recomendado por el CLI es usar un archivo .modyo (ver .modyo).
# - Tanto .env como .modyo deben estar en .gitignore para evitar exponer tokens.
# - Para CI/CD: definir las variables directamente en los secrets del workflow.
#   Ver ejemplo de GitHub Actions en: https://github.com/modyo/modyo-cli#readme
# =============================================================================
